# Deployment environment
ENVIRONMENT=staging

# Core project settings
PROJECT_ID=listygifty
REGION=us-central1
ARTIFACT_REGION=us-central1
ARTIFACT_REPOSITORY=niftygifty

# Cloud SQL (separate DB/user in the same instance to control cost)
SQL_INSTANCE=niftygifty-postgres-central
SQL_DB_VERSION=POSTGRES_17
SQL_EDITION=ENTERPRISE
SQL_TIER=db-f1-micro
SQL_STORAGE_GB=10
SQL_DB_NAME=niftygifty_staging
SQL_DB_USER=niftygifty_staging
SECRET_DB_PASSWORD=niftygifty-staging-db-password
SECRET_DATABASE_URL=niftygifty-staging-database-url

# Runtime identity
RUNTIME_SERVICE_ACCOUNT_NAME=niftygifty-staging-runner

# Heroku source app (for config/data migration)
HEROKU_APP=your-heroku-staging-app
HEROKU_APP_STAGING=your-heroku-staging-app
BINDINGS_OUTPUT=.gcp/heroku-secret-bindings-staging.env

# Cloud Run API
API_SERVICE=niftygifty-staging-api
MIGRATION_JOB=niftygifty-staging-api-migrate
APP_DOMAIN=staging.listygifty.com
API_DOMAIN=api-staging.listygifty.com
FRONTEND_URL=https://staging.listygifty.com
ALLOWED_HOSTS=api-staging.listygifty.com
CORS_ORIGINS=http://localhost:3000,https://staging.listygifty.com
API_MIN_INSTANCES=0
API_MAX_INSTANCES=3
RAILS_ENABLE_YJIT=true
RAILS_MAX_THREADS=3
RAILS_MIN_THREADS=3
DB_POOL=3
WEB_CONCURRENCY=0
PUMA_PERSISTENT_TIMEOUT=20
JOB_THREADS=1

# Secret names used by deploy-api.sh
SECRET_RAILS_MASTER_KEY=niftygifty-staging-rails-master-key
SECRET_CLERK_SECRET_KEY=niftygifty-staging-clerk-secret-key
SECRET_POSTMARK_API_TOKEN=niftygifty-staging-postmark-api-token
SECRET_STRIPE_SECRET_KEY=niftygifty-staging-stripe-secret-key
SECRET_STRIPE_WEBHOOK_SECRET=niftygifty-staging-stripe-webhook-secret
SECRET_OPENAI_API_KEY=niftygifty-staging-openai-api-key
SECRET_POSTHOG_API_KEY=niftygifty-staging-posthog-api-key

# Cloud Run Web
WEB_SERVICE=niftygifty-staging-web
WEB_MIN_INSTANCES=0
WEB_MAX_INSTANCES=3
NEXT_PUBLIC_API_URL=https://api-staging.listygifty.com
NEXT_PUBLIC_APP_URL=https://staging.listygifty.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/signup
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=
SECRET_CLERK_PUBLISHABLE_KEY=niftygifty-staging-clerk-publishable-key
