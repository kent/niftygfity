# Deployment environment
ENVIRONMENT=production

# Core project settings
PROJECT_ID=listygifty
REGION=us-east1
ARTIFACT_REGION=us-east1
ARTIFACT_REPOSITORY=niftygifty

# Cloud SQL
SQL_INSTANCE=niftygifty-postgres
SQL_DB_VERSION=POSTGRES_17
SQL_EDITION=ENTERPRISE
SQL_TIER=db-f1-micro
SQL_STORAGE_GB=10
SQL_DB_NAME=niftygifty_production
SQL_DB_USER=niftygifty
SECRET_DB_PASSWORD=niftygifty-db-password
SECRET_DATABASE_URL=niftygifty-database-url

# Runtime identity
RUNTIME_SERVICE_ACCOUNT_NAME=niftygifty-runner

# Heroku source app (for config/data migration)
HEROKU_APP=niftygifty-production
HEROKU_APP_PRODUCTION=niftygifty-production
BINDINGS_OUTPUT=.gcp/heroku-secret-bindings-production.env

# Cloud Run API
API_SERVICE=niftygifty-api
MIGRATION_JOB=niftygifty-api-migrate
APP_DOMAIN=listygifty.com
API_DOMAIN=api.listygifty.com
FRONTEND_URL=https://listygifty.com
ALLOWED_HOSTS=api.listygifty.com
CORS_ORIGINS=http://localhost:3000,https://listygifty.com,https://www.listygifty.com
API_MIN_INSTANCES=1
API_MAX_INSTANCES=10
RAILS_ENABLE_YJIT=true
RAILS_MAX_THREADS=3
RAILS_MIN_THREADS=3
DB_POOL=3
WEB_CONCURRENCY=0
PUMA_PERSISTENT_TIMEOUT=20
JOB_THREADS=1

# Secret names used by deploy-api.sh
SECRET_RAILS_MASTER_KEY=niftygifty-rails-master-key
SECRET_CLERK_SECRET_KEY=niftygifty-clerk-secret-key
SECRET_POSTMARK_API_TOKEN=niftygifty-postmark-api-token
SECRET_STRIPE_SECRET_KEY=niftygifty-stripe-secret-key
SECRET_STRIPE_WEBHOOK_SECRET=niftygifty-stripe-webhook-secret
SECRET_OPENAI_API_KEY=niftygifty-openai-api-key
SECRET_POSTHOG_API_KEY=niftygifty-posthog-api-key

# Cloud Run Web
WEB_SERVICE=niftygifty-web
WEB_MIN_INSTANCES=0
WEB_MAX_INSTANCES=20
NEXT_PUBLIC_API_URL=https://api.listygifty.com
NEXT_PUBLIC_APP_URL=https://listygifty.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_xxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/signup
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=
SECRET_CLERK_PUBLISHABLE_KEY=niftygifty-clerk-publishable-key
