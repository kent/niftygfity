{
  "name": "niftygifty",
  "private": true,
  "engines": {
    "node": ">=20 <24"
  },
  "workspaces": [
    "apps/web",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "gcp:bootstrap": "bash infra/gcp/scripts/bootstrap.sh",
    "gcp:sync-secrets": "bash infra/gcp/scripts/sync-heroku-secrets.sh",
    "gcp:migrate-db": "bash infra/gcp/scripts/migrate-heroku-db.sh",
    "gcp:verify-db": "bash infra/gcp/scripts/verify-migration.sh",
    "gcp:seed:review": "bash infra/gcp/scripts/seed-app-review-data.sh",
    "gcp:deploy:api": "bash infra/gcp/scripts/deploy-api.sh",
    "gcp:deploy:web": "bash infra/gcp/scripts/deploy-web.sh",
    "gcp:release": "bash infra/gcp/scripts/release.sh"
  },
  "devDependencies": {
    "schema-dts": "^1.1.5",
    "turbo": "^2.3.0"
  },
  "packageManager": "npm@10.2.0",
  "overrides": {
    "react-test-renderer": "19.2.0"
  }
}
